# ── LLM ──────────────────────────────────────────────────────────
# 通用 API key（优先级最高）
API_KEY=
# 自定义端点（OpenAI 兼容格式，如 https://api.openai.com/v1）
API_BASE=
# 模型名
LLM_MODEL=
# 供应商：anthropic / openai / custom
LLM_PROVIDER=anthropic
# 保留向后兼容
ANTHROPIC_API_KEY=

# ── Outlook ───────────────────────────────────────────────────────
OUTLOOK_PROFILE=
INBOX_FOLDER=Inbox
INBOUND_PULL_DAYS=14

# ── 路径 ──────────────────────────────────────────────────────────
DATA_DIR=./data
EXCEL_DEFAULT_DIR=

# ── 行为 ──────────────────────────────────────────────────────────
CHASE_DEFAULT_MODE=draft
SEND_INTERVAL_SECONDS=2
TIMEZONE=Asia/Shanghai

# ── 服务 ──────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
